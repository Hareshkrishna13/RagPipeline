# LLM Configuration
# Uncomment and set the LLM provider you want to use

# ============ OPENAI ============
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_MODEL=gpt-4  # or gpt-3.5-turbo, gpt-4-turbo, etc.

# ============ ANTHROPIC (Claude) ============
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-opus-20240229  # claude-3-sonnet-20240229, claude-3-haiku-20240307

# ============ GROQ (Fast & Free) ============
# GROQ_API_KEY=your-groq-api-key-here
# GROQ_MODEL=mixtral-8x7b-32768  # or llama2-70b, gemma-7b-it, etc.

# ============ OLLAMA (Local LLM) ============
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2  # or mistral, neural-chat, etc.

# ============ GENERAL LLM SETTINGS ============
LLM_PROVIDER=anthropic  # Options: openai, anthropic, groq, ollama, local
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ============ DOCUMENT PROCESSING ============
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============ FAISS INDEX ============
INDEX_PERSISTENCE_DIR=faiss_indices

# ============ LOGGING ============
LOG_LEVEL=INFO
