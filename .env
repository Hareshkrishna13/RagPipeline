# LLM Configuration - Set your API key here
# Uncomment the section below and add your actual API key

# ============ ANTHROPIC (Claude) - RECOMMENDED ============
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ============ OPENAI ============
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_MODEL=gpt-4

# ============ GROQ (Fast, Free, and Recommended!) ============
# GROQ_API_KEY=your-groq-api-key-here
# GROQ_MODEL=mixtral-8x7b-32768
# Available models: mixtral-8x7b-32768, llama2-70b, gemma-7b-it

# ============ GENERAL LLM SETTINGS ============
LLM_PROVIDER=anthropic
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ============ DOCUMENT PROCESSING ============
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============ FAISS INDEX ============
INDEX_PERSISTENCE_DIR=faiss_indices

# ============ LOGGING ============
LOG_LEVEL=INFO
